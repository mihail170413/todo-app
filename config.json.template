{
    "listeners": [
        {"address": "0.0.0.0", "port": 5000}
    ],
    "db_clients": [{
        "rdbms": "postgresql",
        "host": "${DB_HOST}",
        "port": 5432,
        "dbname": "${DB_NAME}",
        "user": "${DB_USER}",
        "passwd": "${DB_PASSWORD}",
        "is_fast": false,
        "connection_number": 4,
        "name": "default"
    }],
    "app": {
        "log": {
            "log_level": "INFO"
        }
    }
}
